/* ========== 弹框样式 ========== */
.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.dialog-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.dialog-form {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.form-value {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333;
  max-width: 60%;
}

.form-value.placeholder {
  color: #CCC;
}

.form-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 12rpx;
}

.form-item-notes {
  flex-direction: column;
  align-items: flex-start;
  border-bottom: none;
}

.notes-input {
  width: 100%;
  min-height: 120rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-top: 16rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 32rpx;
  margin-bottom: calc(15rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, #FF8C42 0%, #FFA86C 100%);
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 66, 0.35);
}

.submit-btn:active {
  opacity: 0.9;
}

.submit-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 选择器样式 - 全屏覆盖 */
.van-action-sheet {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 1000 !important;
}
