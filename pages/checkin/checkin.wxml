<view class="page_container" style="padding-bottom: {{tabBarHeight + 20}}px">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">投喂打卡</text>
    <text class="page-subtitle">记录每一次温暖的相遇</text>
  </view>

  <!-- 选择猫咪 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择猫咪</text>
      <text class="required">*必填</text>
    </view>
    <view class="cat-selector">
      <view class="selected-cat" wx:if="{{selectedCat}}" bind:tap="onShowCatPicker">
        <image class="cat-avatar" src="{{selectedCat.profile_image}}" mode="aspectFill" />
        <view class="cat-info">
          <text class="cat-name">{{selectedCat.name}}</text>
        </view>
        <text class="change-text">更换</text>
      </view>
      <view class="select-cat-btn" wx:else bind:tap="onShowCatPicker">
        <text class="select-icon">+</text>
        <text class="select-text">选择猫咪</text>
      </view>
    </view>
  </view>

  <!-- 投喂信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">投喂信息</text>
    </view>

    <!-- 食物类型 -->
    <view class="form-item" bind:tap="onShowFoodTypePicker">
      <text class="form-label">食物类型 <text class="required">*</text></text>
      <view class="form-value {{feedingData.food_type ? '' : 'placeholder'}}">
        <text wx:if="{{feedingData.food_type}}">{{feedingData.food_type}}</text>
        <text wx:else>请选择食物类型</text>
        <text class="form-arrow">›</text>
      </view>
    </view>

    <!-- 投喂量 -->
    <view class="form-item" bind:tap="onShowAmountPicker">
      <text class="form-label">投喂量 <text class="required">*</text></text>
      <view class="form-value {{feedingData.amount ? '' : 'placeholder'}}">
        <text wx:if="{{feedingData.amount}}">{{feedingData.amount}}</text>
        <text wx:else>请选择投喂量</text>
        <text class="form-arrow">›</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-item form-item-notes">
      <text class="form-label">备注（可选）</text>
      <textarea class="notes-input" placeholder="添加备注说明..." maxlength="100" value="{{feedingData.notes}}" bindinput="onNotesInput" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <van-button
      type="primary"
      size="large"
      bind:tap="onSubmit"
      disabled="{{!canSubmit}}"
      loading="{{submitting}}"
    >
      {{submitting ? '提交中...' : '确认提交'}}
    </van-button>
    <text class="points-hint">完成打卡可获得10积分</text>
  </view>

  <!-- 猫咪选择器 -->
  <van-action-sheet
    show="{{showCatPicker}}"
    actions="{{catPickerActions}}"
    title="选择猫咪"
    bind:close="onCloseCatPicker"
    bind:select="onSelectCat"
  />

  <!-- 食物类型选择器 -->
  <van-action-sheet
    show="{{showFoodTypePicker}}"
    actions="{{foodTypes}}"
    title="选择食物类型"
    bind:close="onCloseFoodTypePicker"
    bind:select="onSelectFoodType"
  />

  <!-- 投喂量选择器 -->
  <van-action-sheet
    show="{{showAmountPicker}}"
    actions="{{amountOptions}}"
    title="选择投喂量"
    bind:close="onCloseAmountPicker"
    bind:select="onSelectAmount"
  />
</view>
