.page_container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF7F0 0%, #F8F9FA 40%);
  display: flex;
  flex-direction: column;
}

/* ========== 聊天头部 ========== */
.chat-header {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.ai-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.ai-avatar image {
  width: 80rpx;
  height: 80rpx;
}

.ai-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.ai-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.ai-status {
  font-size: 24rpx;
  color: #07c160;
  display: flex;
  align-items: center;
}

.ai-status::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  background: #07c160;
  border-radius: 50%;
  margin-right: 12rpx;
}

/* ========== 智能投喂建议卡片 ========== */
.feeding-suggestion-card {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E5 100%);
  border-radius: 20rpx;
  border: 1rpx solid #FFE4D6;
  flex-shrink: 0;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF8C42;
  margin-left: 12rpx;
}

.suggestion-content {
  padding-left: 40rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 聊天消息区域 ========== */
.chat-messages {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  width: 100%;
  box-sizing: border-box;
}

.ai-message {
  justify-content: flex-start;
}

.user-message {
  justify-content: flex-end;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ai-message .message-avatar {
  margin-right: 20rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.user-message .message-avatar {
  margin-left: 20rpx;
}

.message-content {
  max-width: calc(100vw - 200rpx);
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.ai-message .message-content {
  align-items: flex-start;
}

.user-message .message-content {
  align-items: flex-end;
}

.message-bubble {
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 8rpx;
  word-break: break-all;
  box-sizing: border-box;
}

.ai-bubble {
  background: #fff;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  background: linear-gradient(135deg, #FF8C42 0%, #FFA86C 100%);
  border-bottom-right-radius: 8rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.ai-bubble .message-text {
  color: #333;
}

.user-bubble .message-text {
  color: #fff;
}

/* 图片消息 */
.message-image {
  max-width: 300rpx;
  max-height: 400rpx;
  border-radius: 16rpx;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

/* RAG 来源标注 */
.rag-sources {
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  padding: 16rpx 20rpx;
  background: #FFF7F0;
  border-radius: 16rpx;
  max-width: 100%;
  box-sizing: border-box;
}

.rag-label {
  font-size: 22rpx;
  color: #FF8C42;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}

.rag-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.rag-tag {
  font-size: 20rpx;
  color: #666;
  background: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #FFE4D6;
}

/* ========== 快捷问题 ========== */
.quick-questions {
  padding: 20rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.questions-scroll {
  white-space: nowrap;
}

.question-btn {
  display: inline-block;
  padding: 16rpx 28rpx;
  background: #FFF0E5;
  border-radius: 32rpx;
  margin-right: 16rpx;
}

.question-btn text {
  font-size: 26rpx;
  color: #FF8C42;
}

/* ========== 输入区域 ========== */
.chat-input-area {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 相机按钮 */
.camera-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.camera-btn:active {
  transform: scale(0.95);
}

.camera-icon {
  width: 64rpx;
  height: 64rpx;
}

.message-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.send-btn {
  flex-shrink: 0;
}

.send-btn .van-button--primary {
  background: linear-gradient(135deg, #FF8C42 0%, #FFA86C 100%);
  border: none;
}
