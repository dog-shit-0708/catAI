<view class="page_container" style="padding-bottom: {{tabBarHeight + 10}}px">
  <!-- 用户信息卡片 -->
  <view class="user-profile-section">
    <view class="profile-card">
      <view class="profile-header">
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" wx:if="{{userInfo.avatar}}" />
        <image class="user-avatar" src="/assets/11 (360).png" mode="aspectFill" wx:else />
        <view class="user-info">
          <text class="user-name">{{userInfo.nickname}}</text>
          <text class="user-level">爱心志愿者 Lv.{{userLevel}}</text>
          <view class="user-stats">
            <text class="stat-item">积分: {{userPoints}}</text>
            <text class="stat-item">投喂: {{totalFeeding}}次</text>
          </view>
        </view>
        <view class="edit-profile" bind:tap="onEditProfile">
          <text>编辑</text>
        </view>
      </view>

      <!-- 积分进度条 -->
      <view class="points-progress">
        <view class="progress-header">
          <text>距离下一等级还需 {{pointsToNext}} 积分</text>
          <text>{{userPoints}}/{{nextLevelPoints}}</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{progressPercentage}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="achievements-section">
    <view class="section-header">
      <text class="section-title">我的成就</text>
      <text class="achievement-count">{{unlockedAchievements}}/{{totalAchievements}}</text>
    </view>
    <view class="achievements-grid">
      <view wx:for="{{achievements}}" wx:key="id" class="achievement-item {{item.unlocked ? 'unlocked' : 'locked'}}">
        <view class="achievement-icon">
          <text>{{item.icon}}</text>
        </view>
        <text class="achievement-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions-section">
    <view class="section-header">
      <text class="section-title">快速操作</text>
    </view>
    <view class="actions-grid">
      <view class="action-item" bind:tap="onCheckinAction">
        <view class="action-icon checkin">
          <text>📝</text>
        </view>
        <text class="action-name">投喂打卡</text>
      </view>
      <view class="action-item" bind:tap="onViewRecords">
        <view class="action-icon records">
          <text>📊</text>
        </view>
        <text class="action-name">查看记录</text>
      </view>
      <view class="action-item" bind:tap="onViewFavoriteCats">
        <view class="action-icon cats">
          <text>❤️</text>
        </view>
        <text class="action-name">关注猫咪</text>
      </view>
      <view class="action-item" bind:tap="onShareApp">
        <view class="action-icon share">
          <text>📤</text>
        </view>
        <text class="action-name">分享应用</text>
      </view>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="settings-section">
    <view class="section-header">
      <text class="section-title">设置</text>
    </view>
    <van-cell-group>
      <van-cell title="消息通知" is-link bind:tap="onNotificationSettings" />
      <van-cell title="隐私设置" is-link bind:tap="onPrivacySettings" />
      <van-cell title="帮助与反馈" is-link bind:tap="onHelpFeedback" />
      <van-cell title="关于我们" is-link bind:tap="onAboutUs" />
      <van-cell title="退出登录" is-link bind:tap="onLogout" />
    </van-cell-group>
  </view>

  <!-- 投喂打卡组件 -->
  <feeding-checkin 
    visible="{{showCheckinDialog}}" 
    cats="{{cats}}"
    bind:close="onCloseCheckinDialog"
    bind:success="onCheckinSuccess"
    bind:error="onCheckinError"
  />
</view>