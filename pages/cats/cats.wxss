/* 猫咪列表页特有样式 */
page {
  height: 100%;
}

/* ========== 页面头部 ========== */
.page-header {
  margin-bottom: 32rpx;
  padding: 16rpx 8rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #FF8C42;
  font-weight: 500;
}

/* ========== 猫咪列表 ========== */
.cats-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cat-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s, box-shadow 0.2s;
}

.cat-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* ========== 猫咪图片 ========== */
.cat-image-wrapper {
  position: relative;
  width: 100%;
  height: 360rpx;
}

.cat-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx 24rpx 0 0;
}

.cat-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.cat-status.healthy {
  background: #07c160;
  color: #fff;
}

.cat-status.warning {
  background: #FF8C42;
  color: #fff;
}

/* ========== 猫咪信息 ========== */
.cat-info {
  padding: 28rpx;
}

.cat-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.cat-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.cat-alias {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}

.cat-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: #e8f5e8;
  color: #07c160;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.cat-notes {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 元信息 ========== */
.cat-meta {
  display: flex;
  gap: 32rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

/* ========== 加载和空状态 ========== */
.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-state .loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
}
